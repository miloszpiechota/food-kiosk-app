{
  "name": "food-kiosk-app",
  "version": "1.0.0",
  "description": "Production-style food ordering kiosk app with React, NestJS, PostgreSQL, Stripe test payments, accessibility, security, testing and CI/CD.",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "pnpm --parallel --filter @food-kiosk/web --filter @food-kiosk/api dev",
    "dev:web": "pnpm --filter @food-kiosk/web dev",
    "dev:api": "pnpm --filter @food-kiosk/api start:dev",
    "db:format": "pnpm --filter @food-kiosk/database prisma:format",
    "db:generate": "pnpm --filter @food-kiosk/database prisma:generate",
    "db:migrate:deploy": "pnpm --filter @food-kiosk/database prisma:migrate:deploy",
    "db:migrate:dev": "pnpm --filter @food-kiosk/database prisma:migrate:dev",
    "db:seed": "pnpm --filter @food-kiosk/database prisma:seed",
    "db:studio": "pnpm --filter @food-kiosk/database prisma:studio",
    "db:validate": "pnpm --filter @food-kiosk/database prisma:validate",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:restart": "docker compose down && docker compose up -d postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:ps": "docker compose ps",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "prettier": "^3.6.0",
    "prisma": "^6.19.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
